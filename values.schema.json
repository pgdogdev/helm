{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "title": "PgDog Helm Chart Values",
  "description": "Schema for validating PgDog Helm chart values. All object levels use additionalProperties: false to catch typos.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "nameOverride": {
      "type": "string",
      "description": "Override the chart name"
    },
    "fullnameOverride": {
      "type": "string",
      "description": "Override the full release name"
    },
    "labels": {
      "type": "object",
      "description": "Custom labels for resources",
      "additionalProperties": { "type": "string" }
    },
    "selectorLabels": {
      "type": "object",
      "description": "Custom selector labels for resources",
      "additionalProperties": { "type": "string" }
    },
    "annotations": {
      "type": "object",
      "description": "Custom annotations for the deployment",
      "additionalProperties": { "type": "string" }
    },
    "podLabels": {
      "type": "object",
      "description": "Custom labels for pods",
      "additionalProperties": { "type": "string" }
    },
    "podAnnotations": {
      "type": "object",
      "description": "Custom annotations for pods",
      "additionalProperties": { "type": "string" }
    },
    "restartOnConfigChange": {
      "type": "boolean",
      "description": "Trigger rolling restart when pgdog config changes"
    },
    "clusterName": {
      "type": "string",
      "description": "Kubernetes cluster name, added as a label to Prometheus metrics"
    },
    "imagePullSecrets": {
      "type": "array",
      "description": "Image pull secrets for private registries",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name"],
        "properties": {
          "name": { "type": "string" }
        }
      }
    },
    "image": {
      "type": "object",
      "description": "Docker image configuration",
      "additionalProperties": false,
      "properties": {
        "repository": {
          "type": "string",
          "description": "Docker image repository"
        },
        "tag": {
          "type": "string",
          "description": "Docker image tag (defaults to Chart appVersion)"
        },
        "digest": {
          "type": "string",
          "description": "Image digest (overrides tag when specified)"
        },
        "pullPolicy": {
          "type": "string",
          "description": "Image pull policy",
          "enum": ["Always", "IfNotPresent", "Never"]
        },
        "name": {
          "type": "string",
          "description": "DEPRECATED: Full image name (use repository and tag instead)"
        }
      }
    },
    "port": {
      "type": "integer",
      "description": "Port on which PgDog will run",
      "minimum": 1,
      "maximum": 65535
    },
    "healthcheckPort": {
      "type": "integer",
      "description": "Port for healthcheck endpoint",
      "minimum": 1,
      "maximum": 65535
    },
    "replicas": {
      "type": "integer",
      "description": "Number of PgDog replicas",
      "minimum": 1
    },
    "priorityClassName": {
      "type": "string",
      "description": "PriorityClass name for pgdog pods"
    },
    "terminationGracePeriodSeconds": {
      "type": "integer",
      "description": "Grace period for pod termination",
      "minimum": 0
    },
    "preStopSleepSeconds": {
      "type": "integer",
      "description": "Delay before stopping container to allow endpoint updates",
      "minimum": 0
    },
    "strategy": {
      "type": "object",
      "description": "Deployment rollout strategy"
    },
    "livenessProbe": {
      "type": "object",
      "description": "Container liveness probe configuration"
    },
    "readinessProbe": {
      "type": "object",
      "description": "Container readiness probe configuration"
    },
    "startupProbe": {
      "type": "object",
      "description": "Container startup probe configuration"
    },
    "statefulSet": {
      "type": "object",
      "description": "StatefulSet configuration",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Deploy as StatefulSet instead of Deployment"
        }
      }
    },
    "env": {
      "type": "array",
      "description": "Custom environment variables for the pgdog container",
      "items": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": { "type": "string" },
          "value": { "type": "string" },
          "valueFrom": { "type": "object" }
        }
      }
    },
    "extraInitContainers": {
      "type": "array",
      "description": "Additional init containers",
      "items": { "type": "object" }
    },
    "extraVolumes": {
      "type": "array",
      "description": "Additional volumes for the pod",
      "items": { "type": "object" }
    },
    "extraVolumeMounts": {
      "type": "array",
      "description": "Additional volume mounts for the pgdog container",
      "items": { "type": "object" }
    },
    "noCpuLimits": {
      "type": "boolean",
      "description": "Remove CPU limits from containers"
    },
    "resources": {
      "$ref": "#/$defs/resources",
      "description": "Resource requests and limits for the pgdog container"
    },
    "prometheusResources": {
      "$ref": "#/$defs/resources",
      "description": "Resource requests and limits for the prometheus sidecar"
    },
    "openMetricsPort": {
      "type": "integer",
      "description": "Port for OpenMetrics (Prometheus) export",
      "minimum": 1,
      "maximum": 65535
    },
    "prometheusPort": {
      "type": "integer",
      "description": "Port for the Prometheus sidecar",
      "minimum": 1,
      "maximum": 65535
    },
    "openMetricsNamespace": {
      "type": "string",
      "description": "Metrics namespace prefix"
    },
    "logFormat": {
      "type": "string",
      "description": "Log output format",
      "enum": ["text", "json"]
    },
    "logLevel": {
      "type": "string",
      "description": "Log level (RUST_LOG syntax)",
      "enum": ["error", "warn", "info", "debug", "trace", "off"]
    },
    "adminPassword": {
      "type": "string",
      "description": "Admin password for PgDog"
    },
    "databases": {
      "type": "array",
      "description": "Database entries for pgdog.toml",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "host"],
        "properties": {
          "name": { "type": "string" },
          "host": { "type": "string" },
          "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
          "shard": { "type": "integer", "minimum": 0 },
          "databaseName": { "type": "string" },
          "user": { "type": "string" },
          "password": { "type": "string" },
          "poolSize": { "type": "integer", "minimum": 0 },
          "minPoolSize": { "type": "integer", "minimum": 0 },
          "poolerMode": { "type": "string" },
          "statementTimeout": { "type": "integer", "minimum": 0 },
          "idleTimeout": { "type": "integer", "minimum": 0 },
          "readOnly": { "type": "boolean" },
          "role": { "type": "string" },
          "serverLifetime": { "type": "integer", "minimum": 0 },
          "reshardingOnly": { "type": "boolean" },
          "lbWeight": { "type": "integer", "minimum": 0 }
        }
      }
    },
    "users": {
      "type": "array",
      "description": "User entries for users.toml",
      "items": { "type": "object" }
    },
    "mirrors": {
      "type": "array",
      "description": "Mirror database entries",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["sourceDb", "destinationDb"],
        "properties": {
          "sourceDb": { "type": "string" },
          "destinationDb": { "type": "string" },
          "queueLength": { "type": "integer", "minimum": 0 },
          "queueDepth": { "type": "integer", "minimum": 0 },
          "exposure": { "type": "number" },
          "level": { "type": "string" }
        }
      }
    },
    "shardedSchemas": {
      "type": "array",
      "description": "Sharded schema entries",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["database", "shard"],
        "properties": {
          "database": { "type": "string" },
          "name": { "type": "string" },
          "shard": { "type": "integer", "minimum": 0 }
        }
      }
    },
    "shardedTables": {
      "type": "array",
      "description": "Sharded table entries",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["database", "column", "dataType"],
        "properties": {
          "database": { "type": "string" },
          "name": { "type": "string" },
          "column": { "type": "string" },
          "dataType": { "type": "string" }
        }
      }
    },
    "shardedMappings": {
      "type": "array",
      "description": "Sharded mapping entries",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["database", "column", "kind", "shard"],
        "properties": {
          "database": { "type": "string" },
          "column": { "type": "string" },
          "kind": { "type": "string", "enum": ["list", "range"] },
          "shard": { "type": "integer", "minimum": 0 },
          "values": { "type": "array" },
          "start": { "type": "integer" },
          "end": { "type": "integer" }
        }
      }
    },
    "omnishardedTables": {
      "type": "array",
      "description": "Omnisharded table entries",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["database", "tables"],
        "properties": {
          "database": { "type": "string" },
          "sticky": { "type": "boolean" },
          "tables": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "plugins": {
      "type": "array",
      "description": "Plugin entries",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name"],
        "properties": {
          "name": { "type": "string" },
          "config": { "type": "string" }
        }
      }
    },
    "service": {
      "type": "object",
      "description": "Kubernetes service configuration",
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "description": "Service type",
          "enum": ["ClusterIP", "NodePort", "LoadBalancer", "ExternalName"]
        },
        "annotations": {
          "type": "object",
          "description": "Service annotations",
          "additionalProperties": { "type": "string" }
        },
        "trafficDistribution": {
          "type": "string",
          "description": "Traffic distribution mode"
        },
        "aws": {
          "$ref": "#/$defs/awsLb",
          "description": "AWS Load Balancer Controller configuration"
        }
      }
    },
    "nodeSelector": {
      "type": "object",
      "description": "Node selector for pod scheduling",
      "additionalProperties": { "type": "string" }
    },
    "tolerations": {
      "type": "array",
      "description": "Pod tolerations",
      "items": { "type": "object" }
    },
    "affinity": {
      "type": "object",
      "description": "Pod affinity rules"
    },
    "topologySpreadConstraints": {
      "type": "array",
      "description": "Topology spread constraints",
      "items": { "type": "object" }
    },
    "podAntiAffinity": {
      "type": "object",
      "description": "Pod anti-affinity configuration",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Enable default anti-affinity rules"
        },
        "type": {
          "type": "string",
          "description": "Anti-affinity type",
          "enum": ["soft", "hard"]
        }
      }
    },
    "podDisruptionBudget": {
      "type": "object",
      "description": "Pod disruption budget configuration",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Enable PDB"
        },
        "minAvailable": {
          "description": "Minimum available pods (number or percentage string)",
          "oneOf": [
            { "type": "integer", "minimum": 0 },
            { "type": "string", "pattern": "^[0-9]+%$" }
          ]
        },
        "maxUnavailable": {
          "description": "Maximum unavailable pods (number or percentage string)",
          "oneOf": [
            { "type": "integer", "minimum": 0 },
            { "type": "string", "pattern": "^[0-9]+%$" }
          ]
        }
      }
    },
    "serviceAccount": {
      "type": "object",
      "description": "ServiceAccount configuration",
      "additionalProperties": false,
      "properties": {
        "create": {
          "type": "boolean",
          "description": "Create a ServiceAccount"
        },
        "annotations": {
          "type": "object",
          "description": "ServiceAccount annotations",
          "additionalProperties": { "type": "string" }
        },
        "name": {
          "type": "string",
          "description": "ServiceAccount name"
        }
      }
    },
    "rbac": {
      "type": "object",
      "description": "RBAC configuration",
      "additionalProperties": false,
      "properties": {
        "create": {
          "type": "boolean",
          "description": "Create RBAC resources"
        }
      }
    },
    "externalSecrets": {
      "type": "object",
      "description": "ExternalSecrets integration",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Use ExternalSecrets"
        },
        "create": {
          "type": "boolean",
          "description": "Create ExternalSecret resource"
        },
        "name": {
          "type": "string",
          "description": "ExternalSecret name"
        },
        "secretName": {
          "type": "string",
          "description": "Target Kubernetes Secret name"
        },
        "refreshInterval": {
          "type": "string",
          "description": "Sync interval (e.g. 1h)"
        },
        "secretStoreRef": {
          "type": "object",
          "description": "SecretStore reference",
          "additionalProperties": false,
          "properties": {
            "name": { "type": "string" },
            "kind": {
              "type": "string",
              "enum": ["SecretStore", "ClusterSecretStore"]
            }
          }
        },
        "remoteRefs": {
          "type": "array",
          "description": "External secret references",
          "items": { "type": "object" }
        }
      }
    },
    "serviceMonitor": {
      "type": "object",
      "description": "ServiceMonitor for Prometheus",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Enable ServiceMonitor"
        }
      }
    },
    "grafanaRemoteWrite": {
      "type": "object",
      "description": "Grafana remote write configuration",
      "additionalProperties": false,
      "properties": {
        "url": {
          "type": "string",
          "description": "Grafana remote write endpoint URL"
        },
        "basicAuth": {
          "type": "object",
          "description": "Basic auth credentials",
          "additionalProperties": false,
          "properties": {
            "username": { "type": "string" },
            "password": { "type": "string" }
          }
        },
        "queueConfig": {
          "type": "object",
          "description": "Remote write queue configuration",
          "additionalProperties": false,
          "properties": {
            "capacity": { "type": "integer", "minimum": 1 },
            "maxShards": { "type": "integer", "minimum": 1 },
            "minShards": { "type": "integer", "minimum": 1 },
            "maxSamplesPerSend": { "type": "integer", "minimum": 1 },
            "batchSendDeadline": { "type": "string" },
            "minBackoff": { "type": "string" },
            "maxBackoff": { "type": "string" }
          }
        }
      }
    },
    "gateway": {
      "type": "object",
      "description": "Gateway configuration (Enterprise Edition)",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Deploy the gateway"
        },
        "labels": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "selectorLabels": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "image": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "repository": { "type": "string" },
            "tag": { "type": "string" },
            "pullPolicy": {
              "type": "string",
              "enum": ["Always", "IfNotPresent", "Never"]
            },
            "name": { "type": "string" }
          }
        },
        "port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        },
        "bindAddress": { "type": "string" },
        "resources": { "$ref": "#/$defs/resources" },
        "tls": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "existingSecret": { "type": "string" },
            "certPath": { "type": "string" },
            "keyPath": { "type": "string" }
          }
        },
        "control": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "url": { "type": "string" },
            "token": { "type": "string" }
          }
        },
        "stats": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "activeQueriesInterval": { "type": "integer", "minimum": 0 },
            "pingInterval": { "type": "integer", "minimum": 0 },
            "pushInterval": { "type": "integer", "minimum": 0 },
            "configInterval": { "type": "integer", "minimum": 0 },
            "queryStatsInterval": { "type": "integer", "minimum": 0 }
          }
        },
        "service": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "type": {
              "type": "string",
              "enum": ["ClusterIP", "NodePort", "LoadBalancer", "ExternalName"]
            },
            "annotations": {
              "type": "object",
              "additionalProperties": { "type": "string" }
            }
          }
        },
        "nodeSelector": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "tolerations": {
          "type": "array",
          "items": { "type": "object" }
        },
        "affinity": { "type": "object" },
        "connectFromPgdog": {
          "type": "boolean",
          "description": "Enable pgdog to connect to the gateway"
        }
      }
    },
    "queryStats": {
      "type": "object",
      "description": "Query stats (PgDog EE)",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "maxEntries": { "type": "integer", "minimum": 0 },
        "queryPlanThreshold": { "type": "integer", "minimum": 0 },
        "queryPlanMaxAge": { "type": "integer", "minimum": 0 },
        "queryPlansCache": { "type": "integer", "minimum": 0 },
        "maxErrors": { "type": "integer", "minimum": 0 },
        "maxErrorAge": { "type": "integer", "minimum": 0 }
      }
    },
    "control": {
      "type": "object",
      "description": "Control plane configuration (PgDog EE)",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "endpoint": { "type": "string" },
        "token": { "type": "string" },
        "metricsInterval": { "type": "integer", "minimum": 0 },
        "statsInterval": { "type": "integer", "minimum": 0 },
        "activeQueriesInterval": { "type": "integer", "minimum": 0 },
        "errorsInterval": { "type": "integer", "minimum": 0 },
        "requestTimeout": { "type": "integer", "minimum": 0 },
        "queryTimingsChunkSize": { "type": "integer", "minimum": 0 },
        "queryTimingsNewQueryQueueSize": { "type": "integer", "minimum": 0 }
      }
    },
    "workers": {
      "type": "integer",
      "description": "Number of worker threads",
      "minimum": 1
    },
    "defaultPoolSize": {
      "type": "integer",
      "description": "Default connection pool size",
      "minimum": 1
    },
    "minPoolSize": {
      "type": "integer",
      "description": "Minimum connection pool size",
      "minimum": 0
    },
    "poolerMode": {
      "type": "string",
      "description": "Connection pooler mode",
      "enum": ["transaction", "session", "statement"]
    },
    "healthcheckInterval": {
      "type": "integer",
      "description": "Healthcheck interval in ms",
      "minimum": 0
    },
    "idleHealthcheckInterval": {
      "type": "integer",
      "description": "Idle healthcheck interval in ms",
      "minimum": 0
    },
    "idleHealthcheckDelay": {
      "type": "integer",
      "description": "Idle healthcheck delay in ms",
      "minimum": 0
    },
    "healthcheckTimeout": {
      "type": "integer",
      "description": "Healthcheck timeout in ms",
      "minimum": 0
    },
    "banTimeout": {
      "type": "integer",
      "description": "Ban timeout in ms",
      "minimum": 0
    },
    "banReplicaLag": {
      "type": "integer",
      "description": "Ban replica lag threshold in ms",
      "minimum": 0
    },
    "banReplicaLagBytes": {
      "type": "integer",
      "description": "Ban replica lag threshold in bytes",
      "minimum": 0
    },
    "rollbackTimeout": {
      "type": "integer",
      "description": "Rollback timeout in ms",
      "minimum": 0
    },
    "loadBalancingStrategy": {
      "type": "string",
      "description": "Load balancing strategy",
      "enum": ["round_robin", "random", "least_active_connections"]
    },
    "readWriteStrategy": {
      "type": "string",
      "description": "Read/write routing strategy"
    },
    "readWriteSplit": {
      "type": "string",
      "description": "Read/write split mode"
    },
    "connectTimeout": {
      "type": "integer",
      "description": "Connection timeout in ms",
      "minimum": 0
    },
    "connectAttempts": {
      "type": "integer",
      "description": "Number of connection attempts",
      "minimum": 1
    },
    "connectAttemptDelay": {
      "type": "integer",
      "description": "Delay between connection attempts in ms",
      "minimum": 0
    },
    "checkoutTimeout": {
      "type": "integer",
      "description": "Connection checkout timeout in ms",
      "minimum": 0
    },
    "dryRun": {
      "type": ["boolean", "string"],
      "description": "Enable dry run mode"
    },
    "twoPhaseCommit": {
      "type": "boolean",
      "description": "Enable two-phase commit"
    },
    "twoPhaseCommitAuto": {
      "type": "boolean",
      "description": "Enable automatic two-phase commit"
    },
    "twoPhaseCommitWalDir": {
      "type": "string",
      "description": "WAL directory for two-phase commit"
    },
    "twoPhaseCommitWalSegmentSize": {
      "type": "integer",
      "description": "WAL segment size for two-phase commit",
      "minimum": 0
    },
    "twoPhaseCommitWalFsyncInterval": {
      "type": "integer",
      "description": "WAL fsync interval for two-phase commit in ms",
      "minimum": 0
    },
    "twoPhaseCommitWalCheckpointInterval": {
      "type": "integer",
      "description": "WAL checkpoint interval for two-phase commit in ms",
      "minimum": 0
    },
    "systemCatalogs": {
      "type": "string",
      "description": "System catalogs configuration"
    },
    "omnishardedSticky": {
      "type": "boolean",
      "description": "Sticky omnisharded connections"
    },
    "reshardingCopyFormat": {
      "type": "string",
      "description": "Copy format for resharding"
    },
    "reshardingParallelCopies": {
      "type": "integer",
      "description": "Parallel copy count for resharding",
      "minimum": 1
    },
    "reshardingCopyRetryMaxAttempts": {
      "type": "integer",
      "description": "Max retry attempts for resharding copies",
      "minimum": 0
    },
    "reshardingCopyRetryMinDelay": {
      "type": "integer",
      "description": "Min delay between resharding copy retries in ms",
      "minimum": 0
    },
    "reloadSchemaOnDdl": {
      "type": "boolean",
      "description": "Reload schema on DDL statements"
    },
    "loadSchema": {
      "type": "string",
      "description": "Schema loading configuration"
    },
    "tlsGenerateSelfSignedCert": {
      "type": "boolean",
      "description": "Generate self-signed TLS certificate"
    },
    "tlsCertificate": {
      "type": "string",
      "description": "Path to TLS certificate"
    },
    "tlsPrivateKey": {
      "type": "string",
      "description": "Path to TLS private key"
    },
    "tlsClientRequired": {
      "type": ["boolean", "string"],
      "description": "Require TLS client certificates"
    },
    "tlsVerify": {
      "type": "string",
      "description": "TLS verification mode"
    },
    "tlsServerCaCertificate": {
      "type": "string",
      "description": "Path to server CA certificate"
