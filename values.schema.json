          "type": "object",
          "additionalProperties": false,
          "properties": {
            "cpu": { "type": ["string", "number"] },
            "memory": { "type": "string" }
          }
        },
        "limits": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "cpu": { "type": ["string", "number"] },
            "memory": { "type": "string" }
          }
        }
      }
